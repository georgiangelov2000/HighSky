<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="HighSky\Products\Api\ProductSyncInterface"
                type="HighSky\Products\Model\ProductSync"/>
    <preference for="HighSky\Products\Api\Data\ProductSyncItemInterface"
                type="HighSky\Products\Model\Data\ProductSyncItem"/>
