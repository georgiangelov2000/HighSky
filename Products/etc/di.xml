                type="HighSky\Products\Model\Service\ProductSyncService"/>
    <preference for="HighSky\Products\Api\Service\ProductRepositoryInterface"
                type="HighSky\Products\Model\Repository\ProductRepository"/>
    <preference for="HighSky\Products\Api\Validator\RequestValidatorInterface"
                type="HighSky\Products\Model\Validator\RequestValidator"/>
    <preference for="HighSky\Products\Api\Mapper\ProductMapperInterface"
