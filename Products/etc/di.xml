                <item name="notify_stock_qty" xsi:type="string">Notify Stock Qty</item>
                <item name="enable_qty_increments" xsi:type="string">Enable Qty Increments</item>
                <item name="qty_increments" xsi:type="string">Qty Increments</item>
                <item name="variants" xsi:type="string">Variants</item>
            </argument>
        </arguments>
    </type>
</config>
